# Base URL of the control host API (no trailing slash)
TRACKONE_CONTROL_URL=https://control.example.com

# Bearer token from: python manage.py create_monitored_host <name>
TRACKONE_API_TOKEN=

# Seconds between samples
TRACKONE_INTERVAL_SECONDS=30

# Optional - portable / background (see scripts/pack_portable_agent.py)
# TRACKONE_PIDFILE=agent.pid
# TRACKONE_LOGFILE=agent.log
# TRACKONE_CONFIG=C:\full\path\to\config.env
