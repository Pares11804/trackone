# Copy values into your shell (see README) or duplicate this file as `env.local`
# and load manually — Django does not auto-load .env unless you use a tool like direnv.

# --- PostgreSQL (local or remote) ---
POSTGRES_DB=trackone
POSTGRES_USER=trackone
POSTGRES_PASSWORD=change_this_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=dev-only-change-for-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
