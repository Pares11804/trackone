# Copy this file to `.env` next to `manage.py` (same folder as `config/`):
#   copy env.example .env   (Windows: copy env.example .env)
# Then edit `.env`. Django loads it automatically via python-dotenv in config/settings.py.

# --- PostgreSQL (local or remote) ---
# POSTGRES_DB must match the database you created (e.g. trackonedb or trackone).
POSTGRES_DB=trackonedb
POSTGRES_USER=trackone
POSTGRES_PASSWORD=change_this_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=dev-only-change-for-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: default --control-url for `manage.py build_trackoneagent_bundle` (no trailing slash)
# TRACKONE_PUBLIC_BASE_URL=http://192.168.1.50:8000

# Optional: where to write client bundles (default: control_host/agent_bundles/)
# TRACKONE_AGENT_BUNDLE_DIR=C:\path\to\output
